run = "rm -rf node_modules package-lock.json && npm init -y && npm install @whiskeysockets/baileys@6.7.18 @hapi/boom pino && node dlavie-runner"
modules = ["nodejs-20", "python-3.11"]

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node dlavie-runner"
waitForPort = 9000

[[ports]]
localPort = 3000
externalPort = 80

[[ports]]
localPort = 9000
externalPort = 9000

[agent]
expertMode = true

[userenv]

[userenv.shared]
DLAVIE_PHONE_NUMBER = "6285725483343"
DLAVIE_OWNER_NUMBERS = "62882007437216"
